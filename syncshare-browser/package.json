{
  "name": "syncshare-browser",
  "version": "1.0.0",
  "description": "SyncShare Browser - защищенный браузер для работы с системой Modly",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "browser",
    "modly",
    "syncshare",
    "education"
  ],
  "author": "SyncShare",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "ru.syncshare.browser",
    "productName": "SyncShare Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "extension/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "src/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-Portable.${ext}"
    }
  }
}
